# ==========================
# Database — principal
# ==========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=waiona_db
POSTGRES_USER=waiona_user
POSTGRES_PASSWORD=waiona_password

# ==========================
# Database — e2e tests
# Puerto distinto para no pisar datos de dev
# ==========================
POSTGRES_TEST_DB=waiona_test
POSTGRES_TEST_PORT=5433

# ==========================
# pgAdmin
# URL: http://localhost:5050
# ==========================
PGADMIN_EMAIL=admin@waiona.com
PGADMIN_PASSWORD=admin123

# ==========================
# Auth
# ==========================
JWT_SECRET=cambia_esto_en_produccion

# ==========================
# Seed — superadmin inicial
# ==========================
SUPERADMIN_EMAIL=super@admin.com
SUPERADMIN_PASSWORD=cambia_esto_en_produccion

# ==========================
# MercadoPago
# MP_ACCESS_TOKEN → server side, nunca exponer al cliente
# MP_PUBLIC_KEY   → client side, seguro exponer
# MP_NOTIFICATION_URL → URL pública del webhook (ngrok en dev)
# MP_WEBHOOK_SECRET   → desde MP dashboard → Webhooks → secret
# ==========================
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_NOTIFICATION_URL=https://tu-ngrok-url.ngrok-free.app/payments/webhook/mercadopago
MP_WEBHOOK_SECRET=

# ==========================
# Frontend
# ==========================
FRONTEND_URL=http://localhost:4200

# ==========================
# Mail — Resend
# MAIL_FROM → con sandbox solo podés enviar al email de tu cuenta Resend
# En producción: noreply@tudominio.com (requiere dominio verificado en resend.com)
# ==========================
RESEND_API_KEY=
MAIL_FROM=Waiona <onboarding@resend.dev>

# ==========================
# API
# Usado para el logo en los templates de email
# En dev: localhost no es accesible por Resend → usar CDN (Cloudinary, etc.)
# En producción: https://api.tudominio.com
# ==========================
API_URL=http://localhost:3000